---
import CozyMiniGame from "../components/CozyMiniGame.astro";
import { workProjects } from "../data/templateContent";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Selected Work | MODO Design Agency</title>
    <meta
      name="description"
      content="Selected web design, graphic design, and web development work from MODO, a design agency and creative studio."
    />
    <meta
      name="keywords"
      content="MODO selected work, design agency portfolio, web designer portfolio, graphic designer portfolio, web developer portfolio"
    />
    <meta name="author" content="MODO" />
    <meta property="og:title" content="Selected Work | MODO Design Agency" />
    <meta
      property="og:description"
      content="Explore selected work from MODO across web design, graphic design, and web development."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/favicon.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Selected Work | MODO Design Agency" />
    <meta
      name="twitter:description"
      content="Selected work from MODO, a design agency for web design, graphic design, and web development."
    />
    <meta name="twitter:image" content="/favicon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
  </head>
  <body>
    <main class="work-page">
      <img class="work-bg" src="/assets/work/work-studio-bg.png" alt="" aria-hidden="true" />
      <div class="work-noise" aria-hidden="true"></div>

      <header class="work-header">
        <a class="work-back" href="/" aria-label="Back to home" data-sfx="back">Back</a>
      </header>

      <section class="work-select" aria-label="Selected portfolio work">
        {
          workProjects.map((project) => (
            <a class={`work-button ${project.className}`} href="#" data-sfx="panel">
              <img src={project.image} alt="" aria-hidden="true" style={`object-position: ${project.objectPosition}`} />
              <span>{project.title}</span>
            </a>
          ))
        }
      </section>

      <!-- Remove or move this one component to disable/reuse the mini-game. -->
      <CozyMiniGame />

      <a
        class="music-dock"
        href="https://www.youtube.com/watch?v=yKoBrB2dSbw"
        aria-label="Play music on YouTube"
        data-youtube-id="yKoBrB2dSbw"
        data-sfx="music"
      >
        <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
          <source src="/assets/work/cd-player-nobg.mp4" type="video/mp4" />
        </video>
        <span>Play Music</span>
      </a>

      <div class="music-player" data-music-player hidden>
        <iframe
          title="YouTube music player"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </main>

    <script is:inline>
      const clickSoundUrl = "/assets/sounds/ui-click-crisp.m4a?v=3";
      const clickSoundPool = Array.from({ length: 4 }, () => {
        const sound = new Audio(clickSoundUrl);
        sound.preload = "auto";
        sound.volume = 0.58;
        return sound;
      });
      const hoverSoundPool = Array.from({ length: 5 }, () => {
        const sound = new Audio("/assets/sounds/ui-hover-anime.wav");
        sound.preload = "auto";
        sound.volume = 0.42;
        return sound;
      });
      let clickSoundIndex = 0;
      let hoverSoundIndex = 0;
      let lastHover = 0;

      const playFromPool = (pool, index) => {
        const sound = pool[index % pool.length];
        sound.currentTime = 0;
        sound.play().catch(() => {});
        return (index + 1) % pool.length;
      };

      document.querySelectorAll("[data-sfx]").forEach((button) => {
        button.addEventListener("pointerdown", () => {
          clickSoundIndex = playFromPool(clickSoundPool, clickSoundIndex);
        });
      });

      document.querySelectorAll(".work-button, .work-back, .music-dock, .cozy-game").forEach((button) => {
        const playHover = () => {
          const now = performance.now();
          if (now - lastHover < 70) return;
          lastHover = now;
          hoverSoundIndex = playFromPool(hoverSoundPool, hoverSoundIndex);
        };

        button.addEventListener("pointerenter", playHover);
        button.addEventListener("focus", playHover);
      });

      document.querySelectorAll(".work-button[href=\"#\"]").forEach((button) => {
        button.addEventListener("click", (event) => event.preventDefault());
      });

      const musicDock = document.querySelector(".music-dock");
      const musicPlayer = document.querySelector("[data-music-player]");
      const musicFrame = musicPlayer?.querySelector("iframe");

      musicDock?.addEventListener("click", (event) => {
        event.preventDefault();
        const videoId = musicDock.dataset.youtubeId || "yKoBrB2dSbw";
        const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&loop=1&playlist=${videoId}&rel=0`;
        if (musicFrame && musicFrame.src !== embedUrl) {
          musicFrame.src = embedUrl;
        }
        musicPlayer?.removeAttribute("hidden");
        musicDock.classList.add("is-playing");
        const label = musicDock.querySelector("span");
        if (label) label.textContent = "Now Playing";
      });
    </script>
  </body>
</html>
